# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SITE_OWNER_EMAIL: The inbox to receive lead alert notifications
SITE_OWNER_EMAIL="siddharthbose23@gmail.com"

# SMTP Server configuration for sending outbound lead alerts
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="my-service-account@gmail.com"
SMTP_PASS="my-app-password"

# Multi-Factor Authentication TOTP Secrets (Base32 encoded)
# Replace these with rotated random base32 keys in production
VITE_MFA_SECRET_SIDCO9="SIDCOVENTURESADMINSECRETKEYTWO"
VITE_MFA_SECRET_SIDDHARTH="SIDCOVENTURESSIDDHARTHKEYTWO"

